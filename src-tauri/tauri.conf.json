{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "FloatInk",
    "version": "1.0.0",
    "identifier": "com.devtool.floatink",
    "build": {
        "frontendDist": "../src",
        "beforeDevCommand": "",
        "beforeBuildCommand": ""
    },
    "app": {
        "withGlobalTauri": true,
        "macOSPrivateApi": true,
        "windows": [
            {
                "title": "FloatInk",
                "label": "main",
                "width": 1920,
                "height": 1080,
                "resizable": false,
                "maximized": true,
                "visible": false,
                "transparent": true,
                "decorations": false,
                "alwaysOnTop": false,
                "skipTaskbar": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.png"
        ]
    },
    "plugins": {}
}